# ─────────────────────────────────────────────────────────────────────────────
# vivesmedia Hub — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles
# JAMAIS committer .env.local dans Git
# ─────────────────────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXXXXX

# ── ADMIN ─────────────────────────────────────────────────────────────────────
# Email du compte admin (doit correspondre au compte Supabase Auth)

ADMIN_EMAIL=votre@email.com
NEXT_PUBLIC_ADMIN_EMAIL=votre@email.com

# ── RESEND ────────────────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
# Vérifier le domaine vivesmedia.com dans Resend pour envoyer depuis hub@vivesmedia.com

RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# ── ANTHROPIC (IA Hub) ────────────────────────────────────────────────────────
# console.anthropic.com → API Keys → Create Key
# - /api/client/ai/ask      → Assistant IA client (Claude Haiku 4.5)
# - /api/admin/ai/formation → Générateur de modules (Claude Sonnet 4.6)

ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# ── URL APPLICATION ───────────────────────────────────────────────────────────
# Dev local : http://localhost:3001
# Production : https://hub.vivesmedia.com

NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── GOOGLE REVIEWS ────────────────────────────────────────────────────────────
# Google My Business → Partager l'avis → Copier le lien
# Format : https://g.page/r/XXXXXXXXXXXXXXXX/review

GOOGLE_REVIEW_URL=https://g.page/r/XXXXXXXXXXXXXXXXXXXXXXXX/review

# ── N8N (optionnel) ───────────────────────────────────────────────────────────
# URL de base des webhooks n8n — ajouter dans Supabase Database Webhooks
# Ex : https://votre-instance.app.n8n.cloud/webhook

N8N_WEBHOOK_BASE_URL=https://votre-instance.app.n8n.cloud/webhook
